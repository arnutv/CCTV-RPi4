# Force LF on files that run on Linux (RPi)
*.sh            text eol=lf
*.py            text eol=lf
*.service       text eol=lf
*.conf          text eol=lf
Dockerfile      text eol=lf

# Force LF on web files too
*.html          text eol=lf
*.css           text eol=lf
*.js            text eol=lf

# Force CRLF on Windows-only files
*.ps1           text eol=crlf
*.bat           text eol=crlf

# Arduino sources: LF (cross-platform)
*.ino           text eol=lf
*.h             text eol=lf
*.cpp           text eol=lf
*.c             text eol=lf

# CAD / 3D
*.scad          text eol=lf
*.FCMacro       text eol=lf

# Binary files — never touch line endings
*.bin           binary
*.elf           binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.zip           binary
*.gz            binary
*.tar           binary
*.stl           binary
*.step          binary
*.stp           binary
*.3mf           binary
*.FCStd         binary
